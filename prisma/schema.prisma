generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Clinic {
  id        String   @id @default(cuid())
  name      String
  address   String?
  phone     String?
  logo      String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Subscription fields
  subscriptionPlan   String? // "basic", "professional", "enterprise"
  subscriptionStatus String    @default("trial") // "trial", "active", "expired", "cancelled"
  subscriptionStart  DateTime?
  subscriptionEnd    DateTime?
  maxUsers           Int       @default(5)
  maxPatients        Int       @default(100)

  // Relations
  users                      User[]
  patients                   PatientProfile[]
  doctors                    DoctorProfile[]
  appointments               Appointment[]
  medicalRecords             MedicalRecord[]
  scheduleSlots              ScheduleSlot[]
  tasks                      Task[]
  anamnesisVersions          PatientAnamnesisVersion[]
  odontogramSnapshots        OdontogramSnapshot[]
  clinicalEncounters         ClinicalEncounter[]
  clinicalEncounterRevisions ClinicalEncounterRevision[]
  products                   Product[]
  stockMovements             StockMovement[]
  services                   Service[]
  treatmentPlans             TreatmentPlan[]
  treatmentPlanVersions      TreatmentPlanVersion[]
  approvalRequests           ApprovalRequest[]
  cashSessions               CashSession[]
  patientAccountEntries      PatientAccountEntry[]
  patientAccountAllocations  PatientAccountAllocation[]
  accountAllocationReversals PatientAccountAllocationReversal[]
  auditLogs                  AuditLog[]
  patientFiles               PatientFile[]
  financePeriods             FinancePeriod[]
  notificationJobs           NotificationJob[]
  userNotifications          UserNotification[]
  whatsappConversations      WhatsAppConversation[]
  whatsappMessages           WhatsAppMessage[]
  leads                      Lead[]
  crmActivities              CRMActivity[]
  commissionRules            CommissionRule[]
  commissionEntries          CommissionEntry[]
  commissionTransactions     CommissionTransaction[]
  commissionPeriods          CommissionPeriod[]
  commissionSettlements      CommissionSettlement[]
  commissionPayouts          CommissionPayout[]
  warrantyTemplates          WarrantyTemplate[]
  patientWarranties          PatientWarranty[]
  backupJobs                 BackupJob[]

  @@index([active])
  @@index([subscriptionStatus])
}

model User {
  id                      String                      @id @default(cuid())
  email                   String                      @unique
  passwordHash            String
  role                    String
  clinicId                String
  active                  Boolean                     @default(true)
  createdAt               DateTime                    @default(now())
  updatedAt               DateTime                    @updatedAt
  clinic                  Clinic                      @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patientProfile          PatientProfile?
  doctorProfile           DoctorProfile?
  assignedTasks           Task[]                      @relation("TaskAssignee")
  createdTasks            Task[]                      @relation("TaskCreator")
  recordedAnamnesis       PatientAnamnesisVersion[]   @relation("AnamnesisRecorder")
  authoredOdontograms     OdontogramSnapshot[]        @relation("OdontogramAuthor")
  doctorEncounters        ClinicalEncounter[]         @relation("EncounterDoctor")
  encounterRevisions      ClinicalEncounterRevision[] @relation("EncounterRevisionAuthor")
  stockMovements          StockMovement[]             @relation("StockMovementAuthor")
  treatmentPlans          TreatmentPlan[]             @relation("TreatmentPlanDoctor")
  treatmentPlanVersions   TreatmentPlanVersion[]      @relation("TreatmentPlanVersionAuthor")
  requestedApprovals      ApprovalRequest[]           @relation("ApprovalRequester")
  reviewedApprovals       ApprovalRequest[]           @relation("ApprovalReviewer")
  targetedApprovals       ApprovalRequest[]           @relation("ApprovalTargetReviewer")
  openedCashSessions      CashSession[]               @relation("CashSessionOpener")
  closedCashSessions      CashSession[]               @relation("CashSessionCloser")
  patientAccountEntries   PatientAccountEntry[]       @relation("AccountEntryAuthor")
  auditLogs               AuditLog[]
  uploadedPatientFiles    PatientFile[]               @relation("FileUploader")
  closedFinancePeriods    FinancePeriod[]             @relation("PeriodCloser")
  createdLeads            Lead[]                      @relation("LeadCreator")
  assignedLeads           Lead[]                      @relation("LeadAssignee")
  crmActivities           CRMActivity[]               @relation("CRMActivityAuthor")
  commissionRules         CommissionRule[]            @relation("CommissionRuleDoctor")
  commissionEntries       CommissionEntry[]           @relation("CommissionEntryDoctor")
  commissionTransactions  CommissionTransaction[]     @relation("CommissionTransactionDoctor")
  closedCommissionPeriods CommissionPeriod[]          @relation("CommissionPeriodCloser")
  commissionSettlements   CommissionSettlement[]      @relation("CommissionSettlementDoctor")
  paidCommissionPayouts   CommissionPayout[]          @relation("CommissionPayoutPayer")
  completedTreatmentItems TreatmentPlanItem[]         @relation("TreatmentItemCompleter")
  issuedWarranties        PatientWarranty[]           @relation("WarrantyIssuer")
  createdBackupJobs       BackupJob[]                 @relation("BackupCreator")
  notifications           UserNotification[]          @relation("NotificationRecipient")
  assignedWhatsAppChats   WhatsAppConversation[]      @relation("WhatsAppAssignee")
  sentWhatsAppMessages    WhatsAppMessage[]           @relation("WhatsAppSender")

  @@index([clinicId, role])
}

model Task {
  id              String    @id @default(cuid())
  clinicId        String
  title           String
  description     String?
  assigneeUserId  String
  createdByUserId String
  dueDate         DateTime
  status          String    @default("PENDING")
  priority        String    @default("MEDIUM")
  active          Boolean   @default(true)
  completedAt     DateTime?
  cancelledAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  clinic          Clinic    @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  assignee        User      @relation("TaskAssignee", fields: [assigneeUserId], references: [id], onDelete: Restrict)
  createdBy       User      @relation("TaskCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)

  @@index([clinicId, status, dueDate])
  @@index([clinicId, assigneeUserId, status])
  @@index([clinicId, active, dueDate])
}

model PatientProfile {
  id                     String                    @id @default(cuid())
  userId                 String                    @unique
  clinicId               String
  identityNumber         String
  firstName              String
  lastName               String
  phone                  String
  phoneNormalized        String?
  patientType            String                    @default("LOCAL")
  citizenshipCountryCode String                    @default("AZ")
  identityDocumentType   String                    @default("NATIONAL_ID")
  identityDocumentExpiry DateTime?
  preferredLanguage      String                    @default("AZ")
  interpreterRequired    Boolean                   @default(false)
  gender                 String
  birthDate              DateTime
  bloodType              String?
  allergies              String?
  chronicConditions      String?
  createdAt              DateTime                  @default(now())
  updatedAt              DateTime                  @updatedAt
  clinic                 Clinic                    @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  user                   User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  appointments           Appointment[]
  medicalRecords         MedicalRecord[]
  anamnesisVersions      PatientAnamnesisVersion[]
  odontogramSnapshots    OdontogramSnapshot[]
  clinicalEncounters     ClinicalEncounter[]
  treatmentPlans         TreatmentPlan[]
  accountEntries         PatientAccountEntry[]
  files                  PatientFile[]
  commissionEntries      CommissionEntry[]
  warranties             PatientWarranty[]
  whatsappConversation   WhatsAppConversation?

  @@unique([clinicId, citizenshipCountryCode, identityDocumentType, identityNumber])
  @@index([clinicId, lastName, firstName])
  @@index([clinicId, phoneNormalized])
  @@index([clinicId, patientType, citizenshipCountryCode])
}

model DoctorProfile {
  id            String         @id @default(cuid())
  userId        String         @unique
  clinicId      String
  title         String
  firstName     String
  lastName      String
  branch        String
  roomNumber    String?
  active        Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  clinic        Clinic         @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  appointments  Appointment[]
  scheduleSlots ScheduleSlot[]

  @@index([clinicId, branch, active])
}

model Appointment {
  id                 String              @id @default(cuid())
  clinicId           String
  patientId          String
  doctorId           String
  startsAt           DateTime
  endsAt             DateTime
  status             String              @default("PENDING")
  channel            String
  notes              String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  clinic             Clinic              @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patient            PatientProfile      @relation(fields: [patientId], references: [id], onDelete: Restrict)
  doctor             DoctorProfile       @relation(fields: [doctorId], references: [id], onDelete: Restrict)
  clinicalEncounters ClinicalEncounter[]

  @@index([clinicId, doctorId, startsAt])
  @@index([clinicId, patientId, startsAt])
  @@index([clinicId, status, startsAt])
}

model ScheduleSlot {
  id           String        @id @default(cuid())
  clinicId     String
  doctorId     String
  dayOfWeek    Int
  startMinute  Int
  endMinute    Int
  slotDuration Int           @default(15)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  clinic       Clinic        @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  doctor       DoctorProfile @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([clinicId, doctorId, dayOfWeek])
}

model MedicalRecord {
  id            String         @id @default(cuid())
  clinicId      String
  patientId     String
  diagnosis     String
  treatmentPlan String
  prescribedBy  String
  reportType    String         @default("general")
  testResults   Json?
  attachments   Json?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  clinic        Clinic         @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patient       PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([clinicId, patientId, createdAt])
}

model PatientAnamnesisVersion {
  id                 String         @id @default(cuid())
  clinicId           String
  patientId          String
  version            Int
  allergies          Json           @default("[]")
  chronicConditions  Json           @default("[]")
  infectiousDiseases Json           @default("[]")
  regularMedications Json           @default("[]")
  pregnancyOrRisk    String?
  pastSurgeries      String?
  medicalNotes       String?
  criticalAlert      String?
  confirmedByPatient Boolean        @default(false)
  confirmedAt        DateTime?
  recordedByUserId   String
  createdAt          DateTime       @default(now())
  clinic             Clinic         @relation(fields: [clinicId], references: [id], onDelete: Restrict)
  patient            PatientProfile @relation(fields: [patientId], references: [id], onDelete: Restrict)
  recordedBy         User           @relation("AnamnesisRecorder", fields: [recordedByUserId], references: [id], onDelete: Restrict)

  @@unique([patientId, version])
  @@index([clinicId, patientId, createdAt])
}

model OdontogramSnapshot {
  id                  String             @id @default(cuid())
  clinicId            String
  patientId           String
  clinicalEncounterId String?
  numberingSystem     String             @default("FDI")
  dentition           String             @default("PERMANENT")
  entries             Json
  note                String?
  authoredByUserId    String
  createdAt           DateTime           @default(now())
  clinic              Clinic             @relation(fields: [clinicId], references: [id], onDelete: Restrict)
  patient             PatientProfile     @relation(fields: [patientId], references: [id], onDelete: Restrict)
  clinicalEncounter   ClinicalEncounter? @relation(fields: [clinicalEncounterId], references: [id], onDelete: Restrict)
  authoredBy          User               @relation("OdontogramAuthor", fields: [authoredByUserId], references: [id], onDelete: Restrict)

  @@index([clinicId, patientId, createdAt])
  @@index([clinicalEncounterId])
}

model ClinicalEncounter {
  id                  String                      @id @default(cuid())
  clinicId            String
  patientId           String
  appointmentId       String?
  doctorUserId        String
  status              String                      @default("DRAFT")
  complaint           String?
  examination         String?
  diagnosis           String?
  clinicalNotes       String?
  recommendations     String?
  prescription        String?
  nextVisitAt         DateTime?
  signedAt            DateTime?
  completedAt         DateTime?
  createdAt           DateTime                    @default(now())
  updatedAt           DateTime                    @updatedAt
  clinic              Clinic                      @relation(fields: [clinicId], references: [id], onDelete: Restrict)
  patient             PatientProfile              @relation(fields: [patientId], references: [id], onDelete: Restrict)
  appointment         Appointment?                @relation(fields: [appointmentId], references: [id], onDelete: Restrict)
  doctor              User                        @relation("EncounterDoctor", fields: [doctorUserId], references: [id], onDelete: Restrict)
  odontogramSnapshots OdontogramSnapshot[]
  revisions           ClinicalEncounterRevision[]

  @@index([clinicId, patientId, createdAt])
  @@index([clinicId, doctorUserId, status])
  @@index([appointmentId])
}

model ClinicalEncounterRevision {
  id                 String            @id @default(cuid())
  clinicId           String
  encounterId        String
  revision           Int
  reason             String
  previousContent    Json
  replacementContent Json
  authoredByUserId   String
  createdAt          DateTime          @default(now())
  clinic             Clinic            @relation(fields: [clinicId], references: [id], onDelete: Restrict)
  encounter          ClinicalEncounter @relation(fields: [encounterId], references: [id], onDelete: Restrict)
  authoredBy         User              @relation("EncounterRevisionAuthor", fields: [authoredByUserId], references: [id], onDelete: Restrict)

  @@unique([encounterId, revision])
  @@index([clinicId, encounterId, createdAt])
}

model Product {
  id             String          @id @default(cuid())
  clinicId       String
  name           String
  category       String
  sku            String
  unit           String
  minimumStock   Decimal         @default(0) @db.Decimal(14, 3)
  location       String?
  active         Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  clinic         Clinic          @relation(fields: [clinicId], references: [id], onDelete: Restrict)
  stockMovements StockMovement[]

  @@unique([clinicId, sku])
  @@index([clinicId, active, name])
}

model StockMovement {
  id              String   @id @default(cuid())
  clinicId        String
  productId       String
  type            String
  quantity        Decimal  @db.Decimal(14, 3)
  reason          String
  reference       String?
  createdByUserId String
  createdAt       DateTime @default(now())
  clinic          Clinic   @relation(fields: [clinicId], references: [id], onDelete: Restrict)
  product         Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  createdBy       User     @relation("StockMovementAuthor", fields: [createdByUserId], references: [id], onDelete: Restrict)

  @@index([clinicId, productId, createdAt])
  @@index([clinicId, type, createdAt])
}

model Service {
  id              String                @id @default(cuid())
  clinicId        String
  code            String
  name            String
  category        String
  price           Decimal               @db.Decimal(14, 2)
  durationMinutes Int                   @default(30)
  active          Boolean               @default(true)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  clinic          Clinic                @relation(fields: [clinicId], references: [id], onDelete: Restrict)
  treatmentItems  TreatmentPlanItem[]
  accountEntries  PatientAccountEntry[]
  commissionRules CommissionRule[]

  @@unique([clinicId, code])
  @@index([clinicId, active, category])
}

model TreatmentPlan {
  id             String                 @id @default(cuid())
  clinicId       String
  patientId      String
  doctorUserId   String
  title          String
  status         String                 @default("DRAFT")
  currentVersion Int                    @default(1)
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  clinic         Clinic                 @relation(fields: [clinicId], references: [id], onDelete: Restrict)
  patient        PatientProfile         @relation(fields: [patientId], references: [id], onDelete: Restrict)
  doctor         User                   @relation("TreatmentPlanDoctor", fields: [doctorUserId], references: [id], onDelete: Restrict)
  versions       TreatmentPlanVersion[]
  warranties     PatientWarranty[]

  @@index([clinicId, patientId, createdAt])
  @@index([clinicId, status, updatedAt])
}

model TreatmentPlanVersion {
  id              String              @id @default(cuid())
  clinicId        String
  treatmentPlanId String
  version         Int
  discount        Decimal             @default(0) @db.Decimal(14, 2)
  note            String?
  createdByUserId String
  createdAt       DateTime            @default(now())
  clinic          Clinic              @relation(fields: [clinicId], references: [id], onDelete: Restrict)
  treatmentPlan   TreatmentPlan       @relation(fields: [treatmentPlanId], references: [id], onDelete: Restrict)
  createdBy       User                @relation("TreatmentPlanVersionAuthor", fields: [createdByUserId], references: [id], onDelete: Restrict)
  items           TreatmentPlanItem[]

  @@unique([treatmentPlanId, version])
  @@index([clinicId, treatmentPlanId, createdAt])
}

model TreatmentPlanItem {
  id                     String               @id @default(cuid())
  treatmentPlanVersionId String
  serviceId              String
  tooth                  String?
  quantity               Decimal              @default(1) @db.Decimal(14, 3)
  unitPrice              Decimal              @db.Decimal(14, 2)
  status                 String               @default("PLANNED")
  completedAt            DateTime?
  completedByUserId      String?
  accountEntryId         String?              @unique
  treatmentPlanVersion   TreatmentPlanVersion @relation(fields: [treatmentPlanVersionId], references: [id], onDelete: Restrict)
  service                Service              @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  completedBy            User?                @relation("TreatmentItemCompleter", fields: [completedByUserId], references: [id], onDelete: Restrict)
  accountEntry           PatientAccountEntry? @relation(fields: [accountEntryId], references: [id], onDelete: Restrict)

  @@index([treatmentPlanVersionId])
  @@index([serviceId])
  @@index([completedByUserId, completedAt])
}

model CommissionRule {
  id           String   @id @default(cuid())
  clinicId     String
  doctorUserId String?
  serviceId    String?
  percent      Decimal  @db.Decimal(5, 2)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  clinic       Clinic   @relation(fields: [clinicId], references: [id], onDelete: Restrict)
  doctor       User?    @relation("CommissionRuleDoctor", fields: [doctorUserId], references: [id], onDelete: SetNull)
  service      Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)

  @@index([clinicId, active])
  @@index([clinicId, doctorUserId])
  @@index([clinicId, serviceId])
}

model CommissionEntry {
  id             String                  @id @default(cuid())
  clinicId       String
  doctorUserId   String
  patientId      String?
  sourceType     String
  sourceId       String?
  baseAmount     Decimal                 @db.Decimal(14, 2)
  percent        Decimal                 @db.Decimal(5, 2)
  amount         Decimal                 @db.Decimal(14, 2)
  paidBaseAmount Decimal                 @default(0) @db.Decimal(14, 2)
  earnedAmount   Decimal                 @default(0) @db.Decimal(14, 2)
  status         String                  @default("PENDING")
  earnedAt       DateTime?
  note           String?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  clinic         Clinic                  @relation(fields: [clinicId], references: [id], onDelete: Restrict)
  doctor         User                    @relation("CommissionEntryDoctor", fields: [doctorUserId], references: [id], onDelete: Restrict)
  patient        PatientProfile?         @relation(fields: [patientId], references: [id], onDelete: SetNull)
  transactions   CommissionTransaction[]

  @@unique([clinicId, sourceType, sourceId])
  @@index([clinicId, doctorUserId, status])
  @@index([clinicId, createdAt])
  @@index([clinicId, sourceType, sourceId])
}

model CommissionTransaction {
  id                String          @id @default(cuid())
  clinicId          String
  commissionEntryId String
  doctorUserId      String
  type              String
  sourceType        String
  sourceId          String
  baseAmount        Decimal         @db.Decimal(14, 2)
  amount            Decimal         @db.Decimal(14, 2)
  createdAt         DateTime        @default(now())
  clinic            Clinic          @relation(fields: [clinicId], references: [id], onDelete: Restrict)
  commissionEntry   CommissionEntry @relation(fields: [commissionEntryId], references: [id], onDelete: Restrict)
  doctor            User            @relation("CommissionTransactionDoctor", fields: [doctorUserId], references: [id], onDelete: Restrict)

  @@unique([clinicId, type, sourceId])
  @@index([clinicId, doctorUserId, createdAt])
  @@index([commissionEntryId, createdAt])
}

model CommissionPeriod {
  id             String                 @id @default(cuid())
  clinicId       String
  startDate      DateTime
  endDate        DateTime
  status         String                 @default("CLOSED")
  totalAmount    Decimal                @default(0) @db.Decimal(14, 2)
  note           String?
  closedByUserId String
  closedAt       DateTime               @default(now())
  createdAt      DateTime               @default(now())
  clinic         Clinic                 @relation(fields: [clinicId], references: [id], onDelete: Restrict)
  closedBy       User                   @relation("CommissionPeriodCloser", fields: [closedByUserId], references: [id], onDelete: Restrict)
  settlements    CommissionSettlement[]

  @@unique([clinicId, startDate, endDate])
  @@index([clinicId, endDate])
}

model CommissionSettlement {
  id           String             @id @default(cuid())
  clinicId     String
  periodId     String
  doctorUserId String
  earnedAmount Decimal            @db.Decimal(14, 2)
  paidAmount   Decimal            @default(0) @db.Decimal(14, 2)
  status       String             @default("UNPAID")
  paidAt       DateTime?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  clinic       Clinic             @relation(fields: [clinicId], references: [id], onDelete: Restrict)
  period       CommissionPeriod   @relation(fields: [periodId], references: [id], onDelete: Restrict)
  doctor       User               @relation("CommissionSettlementDoctor", fields: [doctorUserId], references: [id], onDelete: Restrict)
  payouts      CommissionPayout[]

  @@unique([periodId, doctorUserId])
  @@index([clinicId, doctorUserId, status])
}

model CommissionPayout {
  id            String               @id @default(cuid())
  clinicId      String
  settlementId  String
  amount        Decimal              @db.Decimal(14, 2)
  paymentMethod String
  reference     String?
  note          String?
  paidByUserId  String
  cashSessionId String?
  paidAt        DateTime             @default(now())
  clinic        Clinic               @relation(fields: [clinicId], references: [id], onDelete: Restrict)
  settlement    CommissionSettlement @relation(fields: [settlementId], references: [id], onDelete: Restrict)
  paidBy        User                 @relation("CommissionPayoutPayer", fields: [paidByUserId], references: [id], onDelete: Restrict)
  cashSession   CashSession?         @relation(fields: [cashSessionId], references: [id], onDelete: Restrict)

  @@index([clinicId, paidAt])
  @@index([settlementId, paidAt])
  @@index([cashSessionId, paidAt])
}

model WarrantyTemplate {
  id           String            @id @default(cuid())
  clinicId     String
  name         String
  durationDays Int
  conditions   String?
  active       Boolean           @default(true)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  clinic       Clinic            @relation(fields: [clinicId], references: [id], onDelete: Restrict)
  warranties   PatientWarranty[]

  @@index([clinicId, active])
}

model PatientWarranty {
  id              String            @id @default(cuid())
  clinicId        String
  patientId       String
  treatmentPlanId String?
  templateId      String?
  title           String
  issuedAt        DateTime          @default(now())
  expiresAt       DateTime
  status          String            @default("ACTIVE")
  note            String?
  createdByUserId String
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  clinic          Clinic            @relation(fields: [clinicId], references: [id], onDelete: Restrict)
  patient         PatientProfile    @relation(fields: [patientId], references: [id], onDelete: Restrict)
  treatmentPlan   TreatmentPlan?    @relation(fields: [treatmentPlanId], references: [id], onDelete: SetNull)
  template        WarrantyTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  createdBy       User              @relation("WarrantyIssuer", fields: [createdByUserId], references: [id], onDelete: Restrict)

  @@index([clinicId, patientId, status])
  @@index([clinicId, expiresAt])
}

model ApprovalRequest {
  id                String    @id @default(cuid())
  clinicId          String
  requestedByUserId String
  reviewerRole      String
  reviewerUserId    String?
  actionType        String
  entityType        String
  entityId          String?
  payload           Json
  status            String    @default("PENDING")
  reviewNote        String?
  reviewedByUserId  String?
  reviewedAt        DateTime?
  appliedAt         DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  clinic            Clinic    @relation(fields: [clinicId], references: [id], onDelete: Restrict)
  requestedBy       User      @relation("ApprovalRequester", fields: [requestedByUserId], references: [id], onDelete: Restrict)
  reviewedBy        User?     @relation("ApprovalReviewer", fields: [reviewedByUserId], references: [id], onDelete: Restrict)
  reviewerUser      User?     @relation("ApprovalTargetReviewer", fields: [reviewerUserId], references: [id], onDelete: Restrict)

  @@index([clinicId, reviewerRole, status, createdAt])
  @@index([clinicId, requestedByUserId, status])
  @@index([clinicId, reviewerUserId, status])
}

model CashSession {
  id                String                @id @default(cuid())
  clinicId          String
  openedByUserId    String
  closedByUserId    String?
  openingBalance    Decimal               @default(0) @db.Decimal(14, 2)
  expectedBalance   Decimal?              @db.Decimal(14, 2)
  countedBalance    Decimal?              @db.Decimal(14, 2)
  status            String                @default("OPEN")
  openNote          String?
  closeNote         String?
  openedAt          DateTime              @default(now())
  closedAt          DateTime?
  clinic            Clinic                @relation(fields: [clinicId], references: [id], onDelete: Restrict)
  openedBy          User                  @relation("CashSessionOpener", fields: [openedByUserId], references: [id], onDelete: Restrict)
  closedBy          User?                 @relation("CashSessionCloser", fields: [closedByUserId], references: [id], onDelete: Restrict)
  accountEntries    PatientAccountEntry[]
  commissionPayouts CommissionPayout[]

  @@index([clinicId, status, openedAt])
}

model PatientAccountEntry {
  id                  String                             @id @default(cuid())
  clinicId            String
  patientId           String
  entryType           String
  direction           String
  amount              Decimal                            @db.Decimal(14, 2)
  paymentMethod       String?
  referenceType       String?
  referenceId         String?
  serviceId           String?
  description         String
  receiptNumber       String?
  cashSessionId       String?
  createdByUserId     String
  createdAt           DateTime                           @default(now())
  clinic              Clinic                             @relation(fields: [clinicId], references: [id], onDelete: Restrict)
  patient             PatientProfile                     @relation(fields: [patientId], references: [id], onDelete: Restrict)
  service             Service?                           @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  cashSession         CashSession?                       @relation(fields: [cashSessionId], references: [id], onDelete: Restrict)
  createdBy           User                               @relation("AccountEntryAuthor", fields: [createdByUserId], references: [id], onDelete: Restrict)
  debitAllocations    PatientAccountAllocation[]         @relation("AllocationDebit")
  creditAllocations   PatientAccountAllocation[]         @relation("AllocationCredit")
  allocationReversals PatientAccountAllocationReversal[] @relation("AllocationRefundEntry")
  treatmentPlanItem   TreatmentPlanItem?

  @@index([clinicId, patientId, createdAt])
  @@index([clinicId, cashSessionId, createdAt])
  @@index([clinicId, entryType, createdAt])
}

model PatientAccountAllocation {
  id            String                             @id @default(cuid())
  clinicId      String
  debitEntryId  String
  creditEntryId String
  amount        Decimal                            @db.Decimal(14, 2)
  createdAt     DateTime                           @default(now())
  clinic        Clinic                             @relation(fields: [clinicId], references: [id], onDelete: Restrict)
  debitEntry    PatientAccountEntry                @relation("AllocationDebit", fields: [debitEntryId], references: [id], onDelete: Restrict)
  creditEntry   PatientAccountEntry                @relation("AllocationCredit", fields: [creditEntryId], references: [id], onDelete: Restrict)
  reversals     PatientAccountAllocationReversal[]

  @@unique([debitEntryId, creditEntryId])
  @@index([clinicId, debitEntryId])
  @@index([clinicId, creditEntryId])
}

model PatientAccountAllocationReversal {
  id            String                   @id @default(cuid())
  clinicId      String
  allocationId  String
  refundEntryId String
  amount        Decimal                  @db.Decimal(14, 2)
  createdAt     DateTime                 @default(now())
  clinic        Clinic                   @relation(fields: [clinicId], references: [id], onDelete: Restrict)
  allocation    PatientAccountAllocation @relation(fields: [allocationId], references: [id], onDelete: Restrict)
  refundEntry   PatientAccountEntry      @relation("AllocationRefundEntry", fields: [refundEntryId], references: [id], onDelete: Restrict)

  @@unique([allocationId, refundEntryId])
  @@index([clinicId, refundEntryId])
  @@index([clinicId, allocationId])
}

model AuditLog {
  id         String   @id @default(cuid())
  clinicId   String?
  userId     String?
  userEmail  String?
  userRole   String?
  category   String
  action     String
  entityType String?
  entityId   String?
  summary    String
  details    Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
  clinic     Clinic?  @relation(fields: [clinicId], references: [id], onDelete: Restrict)
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([clinicId, createdAt])
  @@index([clinicId, category, createdAt])
  @@index([clinicId, action, createdAt])
  @@index([userId, createdAt])
}

model PatientFile {
  id               String         @id @default(cuid())
  clinicId         String
  patientId        String
  uploadedByUserId String
  originalName     String
  mimeType         String
  sizeBytes        Int
  storageKey       String
  content          Bytes?
  contentSha256    String?
  category         String         @default("GENERAL")
  createdAt        DateTime       @default(now())
  clinic           Clinic         @relation(fields: [clinicId], references: [id], onDelete: Restrict)
  patient          PatientProfile @relation(fields: [patientId], references: [id], onDelete: Restrict)
  uploadedBy       User           @relation("FileUploader", fields: [uploadedByUserId], references: [id], onDelete: Restrict)

  @@index([clinicId, patientId, createdAt])
}

model FinancePeriod {
  id             String   @id @default(cuid())
  clinicId       String
  closedThrough  DateTime @db.Date
  closedByUserId String
  closedAt       DateTime @default(now())
  note           String?
  summary        Json?
  clinic         Clinic   @relation(fields: [clinicId], references: [id], onDelete: Restrict)
  closedBy       User     @relation("PeriodCloser", fields: [closedByUserId], references: [id], onDelete: Restrict)

  @@index([clinicId, closedThrough])
}

model NotificationJob {
  id          String    @id @default(cuid())
  clinicId    String
  type        String
  channel     String
  recipient   String
  payload     Json
  status      String    @default("PENDING")
  scheduledAt DateTime
  sentAt      DateTime?
  error       String?
  createdAt   DateTime  @default(now())
  clinic      Clinic    @relation(fields: [clinicId], references: [id], onDelete: Restrict)

  @@index([clinicId, status, scheduledAt])
}

model UserNotification {
  id              String    @id @default(cuid())
  clinicId        String
  recipientUserId String
  type            String
  title           String
  message         String
  href            String?
  entityType      String?
  entityId        String?
  readAt          DateTime?
  createdAt       DateTime  @default(now())
  clinic          Clinic    @relation(fields: [clinicId], references: [id], onDelete: Restrict)
  recipient       User      @relation("NotificationRecipient", fields: [recipientUserId], references: [id], onDelete: Restrict)

  @@index([recipientUserId, readAt, createdAt])
  @@index([clinicId, type, createdAt])
}

model WhatsAppConversation {
  id             String            @id @default(cuid())
  clinicId       String
  patientId      String            @unique
  assignedUserId String?
  phone          String
  lastMessageAt  DateTime?
  lastInboundAt  DateTime?
  lastOutboundAt DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  clinic         Clinic            @relation(fields: [clinicId], references: [id], onDelete: Restrict)
  patient        PatientProfile    @relation(fields: [patientId], references: [id], onDelete: Restrict)
  assignedUser   User?             @relation("WhatsAppAssignee", fields: [assignedUserId], references: [id], onDelete: SetNull)
  messages       WhatsAppMessage[]

  @@index([clinicId, lastMessageAt])
  @@index([clinicId, assignedUserId, lastInboundAt])
  @@index([clinicId, phone])
}

model WhatsAppMessage {
  id                String               @id @default(cuid())
  clinicId          String
  conversationId    String
  sentByUserId      String?
  providerMessageId String?              @unique
  direction         String
  messageType       String               @default("TEXT")
  body              String?
  status            String               @default("RECEIVED")
  occurredAt        DateTime
  createdAt         DateTime             @default(now())
  clinic            Clinic               @relation(fields: [clinicId], references: [id], onDelete: Restrict)
  conversation      WhatsAppConversation @relation(fields: [conversationId], references: [id], onDelete: Restrict)
  sentBy            User?                @relation("WhatsAppSender", fields: [sentByUserId], references: [id], onDelete: SetNull)

  @@index([clinicId, conversationId, occurredAt])
  @@index([clinicId, direction, occurredAt])
}

model BackupJob {
  id              String    @id @default(cuid())
  clinicId        String
  createdByUserId String
  type            String    @default("MANUAL")
  status          String    @default("PENDING")
  storageKey      String?
  summary         Json?
  error           String?
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  clinic          Clinic    @relation(fields: [clinicId], references: [id], onDelete: Restrict)
  createdBy       User      @relation("BackupCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)

  @@index([clinicId, status, createdAt])
  @@index([clinicId, createdAt])
}

model Lead {
  id                 String        @id @default(cuid())
  clinicId           String
  fullName           String
  phone              String
  source             String        @default("OTHER")
  status             String        @default("NEW")
  interest           String?
  note               String?
  assignedToUserId   String?
  createdByUserId    String
  convertedPatientId String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  clinic             Clinic        @relation(fields: [clinicId], references: [id], onDelete: Restrict)
  createdBy          User          @relation("LeadCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  assignedTo         User?         @relation("LeadAssignee", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  activities         CRMActivity[]

  @@index([clinicId, status, createdAt])
  @@index([clinicId, phone])
  @@index([clinicId, assignedToUserId, status])
}

model CRMActivity {
  id              String    @id @default(cuid())
  clinicId        String
  leadId          String?
  patientId       String?
  type            String
  channel         String    @default("PHONE")
  summary         String
  nextActionAt    DateTime?
  createdByUserId String
  createdAt       DateTime  @default(now())
  clinic          Clinic    @relation(fields: [clinicId], references: [id], onDelete: Restrict)
  lead            Lead?     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  createdBy       User      @relation("CRMActivityAuthor", fields: [createdByUserId], references: [id], onDelete: Restrict)

  @@index([clinicId, leadId, createdAt])
  @@index([clinicId, patientId, createdAt])
  @@index([clinicId, type, createdAt])
}
