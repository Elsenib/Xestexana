DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hospital_platform
REDIS_URL=redis://localhost:6379
JWT_SECRET=replace-with-at-least-32-random-characters
ADMIN_SETUP_KEY=replace-with-a-private-setup-key
PORT=4000
HOST=0.0.0.0

# Optional WhatsApp Business Cloud API (required for inbound replies in the app)
WHATSAPP_VERIFY_TOKEN=replace-with-a-private-webhook-verify-token
WHATSAPP_APP_SECRET=replace-with-meta-app-secret
WHATSAPP_PHONE_NUMBER_ID=replace-with-meta-phone-number-id
WHATSAPP_CLINIC_ID=replace-with-clinic-id

# Optional payment integration (currently not registered in the API)
PAYMES_API_KEY=your_paymes_api_key_here
PAYMES_MERCHANT=your_paymes_merchant_id_here
