{
  "appId": "com.xestexana.desktop",
  "productName": "Xestexana Platform",
  "directories": {
    "output": "dist_electron"
  },
  "files": [
    "main.js",
    "server.js",
    "build/icon.ico",
    "build/icon-256.png",
    "out/**",
    "package.json"
  ],
  "win": {
    "icon": "build/icon-256.png",
